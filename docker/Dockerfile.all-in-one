# BabelCast All-in-One — Single container with bot + pipeline + orchestrator
#
# Services running inside:
#   :8080  — orchestrator (gateway-facing: /join, /transcripts, /ws/audio)
#   :8090  — meet-teams-bot (internal, proxied by orchestrator)
#   :8000  — translation pipeline (Whisper STT + Groq, internal)
#
# The gateway points botEndpoint at :8080 on this machine.
#
# Build args:
#   CONF_LLM_MODEL=groq  (default)

FROM runpod/pytorch:2.4.0-py3.11-cuda12.4.1-devel-ubuntu22.04

ENV PYTHONUNBUFFERED=1
ENV PYTHONDONTWRITEBYTECODE=1
ENV CONF_LLM_MODEL=groq
# Bot display/audio
ENV DISPLAY=:99
ENV PULSE_RUNTIME_PATH=/tmp/pulse
ENV XDG_RUNTIME_DIR=/tmp/pulse
ENV NODE_OPTIONS="--max-old-space-size=2048"
ENV SERVERLESS=true
ENV NODE_ENV=production

WORKDIR /app

# ── System deps: Python pipeline + Node.js/Chromium bot ──────────────────────
RUN apt-get update && apt-get install -y --no-install-recommends \
    # Pipeline deps
    ffmpeg libsndfile1 sox libsox-dev curl \
    # Node.js 20
    ca-certificates gnupg \
    # Bot: virtual display + audio
    xvfb x11vnc x11-utils pulseaudio pulseaudio-utils unclutter \
    # Bot: Chromium system libs
    libnss3 libatk-bridge2.0-0 libdrm2 libxkbcommon0 \
    libxcomposite1 libxdamage1 libxrandr2 libgbm1 libxss1 libxshmfence1 \
    libgtk-3-0 libgdk-pixbuf2.0-0 \
    # Utilities
    wget unzip rsync \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# ── Python: Whisper + Groq + FastAPI ─────────────────────────────────────────
RUN pip install --no-cache-dir --upgrade torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu124

RUN pip install --no-cache-dir \
    "faster-whisper>=1.1.0" \
    "fastapi>=0.115.0" "uvicorn[standard]>=0.32.0" \
    python-multipart httpx soundfile numpy \
    "huggingface-hub>=0.26.0" hf_transfer \
    "pydantic-settings>=2.0" websockets

RUN pip install --no-cache-dir "transformers==4.57.3" "accelerate>=1.12.0" \
    librosa einops onnxruntime && \
    pip install --no-cache-dir --no-deps "qwen-tts>=0.1.1" && \
    pip install --no-cache-dir --no-deps "faster-qwen3-tts>=0.2.1"

RUN pip install --no-cache-dir pyannote.audio && \
    pip install --no-cache-dir --upgrade torch torchvision torchaudio \
    --index-url https://download.pytorch.org/whl/cu124

RUN rm -rf /root/.cache/pip /tmp/pip-*

# ── Bot: build Node.js app (port patched 8080 → 8090) ────────────────────────
COPY teams-bot/package.json teams-bot/package-lock.json /app/bot/
WORKDIR /app/bot
# Use NODE_ENV=development so npm ci includes devDependencies (TypeScript needs tsc)
RUN NODE_ENV=development npm ci

# Install Playwright Chromium
RUN npx playwright install chromium && \
    find /root/.cache/ms-playwright -name chrome -type f -executable | head -1 | \
    xargs -I {} ln -sf {} /usr/bin/google-chrome

# Copy source, patch port, build, then prune devDeps
COPY teams-bot/ /app/bot/
RUN sed -i 's/const PORT = 8080/const PORT = 8090/' src/server.ts && \
    npm run build && \
    npm prune --production

# ── Pipeline: copy API code ───────────────────────────────────────────────────
WORKDIR /app
COPY api/ /app/api/

# ── Orchestrator: copy Python service ────────────────────────────────────────
COPY all-in-one/orchestrator/main.py /app/orchestrator/main.py
COPY all-in-one/orchestrator/requirements.txt /app/orchestrator/requirements.txt
RUN pip install --no-cache-dir -r /app/orchestrator/requirements.txt

# ── Startup script ────────────────────────────────────────────────────────────
COPY start-all-in-one.sh /app/start-all-in-one.sh
RUN chmod +x /app/start-all-in-one.sh

# gateway-facing port
EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=10s --retries=10 --start-period=180s \
    CMD curl -f http://localhost:8080/health || exit 1

CMD ["/app/start-all-in-one.sh"]
