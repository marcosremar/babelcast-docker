# BabelCast All-in-One — Environment Variables
# Copy to .env and fill in values before running docker compose up

# Required: Groq Cloud API key (https://console.groq.com)
CONF_GROQ_API_KEY=gsk_...

# Optional: HuggingFace token (needed for pyannote speaker embeddings)
HF_TOKEN=hf_...

# Language pair
CONF_SOURCE_LANG=pt
CONF_TARGET_LANG=en

# Set to 0 to disable hot-update from GitHub (use baked-in code instead)
BABELCAST_HOT_UPDATE=1
